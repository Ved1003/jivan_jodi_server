{
  "name": "jivan-jodi-backend",
  "version": "1.0.0",
  "description": "Backend API for Jivan Jodi Matrimonial Platform",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:dev": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop jivan-jodi-api",
    "pm2:restart": "pm2 restart jivan-jodi-api",
    "pm2:reload": "pm2 reload jivan-jodi-api",
    "pm2:delete": "pm2 delete jivan-jodi-api",
    "pm2:logs": "pm2 logs jivan-jodi-api",
    "pm2:monit": "pm2 monit",
    "pm2:status": "pm2 status",
    "pm2:flush": "pm2 flush",
    "pm2:save": "pm2 save",
    "pm2:startup": "pm2 startup",
    "logs:clear": "rm -rf logs/*.log || del /Q logs\\*.log"
  },
  "keywords": [
    "matrimonial",
    "api",
    "nodejs",
    "express"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^1.41.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "multer-storage-cloudinary": "^4.0.0",
    "mysql2": "^3.16.0",
    "node-fetch": "^2.7.0",
    "nodemailer": "^7.0.12",
    "pm2": "^5.4.3",
    "razorpay": "^2.9.6",
    "winston": "^3.19.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2"
  }
}